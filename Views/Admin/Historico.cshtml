@model List<ReservaInfo>
@{
    ViewData["Title"] = "Histórico de Reservas";
}

<div class="container-fluid py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-clock-history"></i> Histórico de Reservas</h2>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Hóspede</th>
                                <th>Quarto</th>
                                <th>Entrada</th>
                                <th>Saída</th>
                                <th>Status Final</th>
                                <th>Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                <tr>
                                    <td><code>@r.Id.Substring(0, 8)...</code></td>
                                    <td>@r.NomeHospede</td>
                                    <td>@r.TipoQuarto</td>
                                    <td>@r.DataEntrada.ToString("dd/MM/yyyy")</td>
                                    <td>@r.DataSaida.ToString("dd/MM/yyyy")</td>
                                    <td><span class="status-badge status-@r.Status.ToLower()">@r.Status</span></td>
                                    <td>R$ @r.ValorTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center">Nenhum registro no histórico</p>
            }
        </div>
    </div>
</div>

@model Reserva
@{
    ViewData["Title"] = "Detalhes da Reserva";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-receipt"></i> Detalhes da Reserva</h4>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="text-muted"><i class="bi bi-hash"></i> Código</h6>
                            <p class="fs-5"><code>@Model.Id</code></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted"><i class="bi bi-flag"></i> Status</h6>
                            <p><span class="status-badge status-@Model.Status.ToString().ToLower()">@Model.Status</span></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted"><i class="bi bi-person"></i> Hóspede</h6>
                            <p><strong>@Model.NomeHospede</strong></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted"><i class="bi bi-envelope"></i> Contato</h6>
                            <p>@Model.EmailHospede<br>@Model.TelefoneHospede</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted"><i class="bi bi-door-open"></i> Quarto</h6>
                            <p><strong>@Model.TipoQuarto</strong></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted"><i class="bi bi-people"></i> Hóspedes</h6>
                            <p>@Model.NumeroHospedes pessoa(s)</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted"><i class="bi bi-calendar-event"></i> Check-in</h6>
                            <p>@Model.DataEntrada.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted"><i class="bi bi-calendar-check"></i> Check-out</h6>
                            <p>@Model.DataSaida.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="col-12">
                            <h6 class="text-muted"><i class="bi bi-currency-dollar"></i> Valor Total</h6>
                            <p class="fs-3 text-success fw-bold">R$ @Model.ValorTotal.ToString("N2")</p>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.TipoPacote))
                        {
                            <div class="col-12">
                                <h6 class="text-muted"><i class="bi bi-gift"></i> Pacote</h6>
                                <p>@Model.TipoPacote</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Observacoes))
                        {
                            <div class="col-12">
                                <h6 class="text-muted"><i class="bi bi-chat"></i> Observações</h6>
                                <p class="bg-light p-2 rounded">@Model.Observacoes</p>
                            </div>
                        }
                    </div>

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-outline-primary">
                            <i class="bi bi-arrow-left"></i> Voltar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

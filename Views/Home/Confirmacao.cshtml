@model Reserva
@{
    ViewData["Title"] = "Reserva Confirmada";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white py-4 text-center">
                    <i class="bi bi-check-circle-fill fs-1"></i>
                    <h2 class="mt-2 mb-0">Reserva Confirmada!</h2>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <p class="text-muted">Código da Reserva</p>
                        <h3 class="fw-bold text-primary">@Model.Id</h3>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <h6 class="text-muted mb-3"><i class="bi bi-person"></i> Dados do Hóspede</h6>
                                <p class="mb-1"><strong>Nome:</strong> @Model.NomeHospede</p>
                                <p class="mb-1"><strong>Email:</strong> @Model.EmailHospede</p>
                                <p class="mb-0"><strong>Telefone:</strong> @Model.TelefoneHospede</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <h6 class="text-muted mb-3"><i class="bi bi-calendar"></i> Datas</h6>
                                <p class="mb-1"><strong>Check-in:</strong> @Model.DataEntrada.ToString("dd/MM/yyyy")</p>
                                <p class="mb-1"><strong>Check-out:</strong> @Model.DataSaida.ToString("dd/MM/yyyy")</p>
                                <p class="mb-0"><strong>Diárias:</strong> @((Model.DataSaida - Model.DataEntrada).Days)</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <h6 class="text-muted mb-3"><i class="bi bi-door-open"></i> Acomodação</h6>
                                <p class="mb-1"><strong>Quarto:</strong> @Model.TipoQuarto</p>
                                <p class="mb-1"><strong>Hóspedes:</strong> @Model.NumeroHospedes</p>
                                @if (!string.IsNullOrEmpty(Model.TipoPacote))
                                {
                                    <p class="mb-0"><strong>Pacote:</strong> @Model.TipoPacote</p>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100 bg-light">
                                <h6 class="text-muted mb-3"><i class="bi bi-currency-dollar"></i> Valor Total</h6>
                                <p class="fs-3 fw-bold text-success mb-0">R$ @Model.ValorTotal.ToString("N2")</p>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Observacoes))
                    {
                        <div class="mt-4">
                            <h6 class="text-muted"><i class="bi bi-chat-left-text"></i> Observações</h6>
                            <p class="border rounded p-3 bg-light">@Model.Observacoes</p>
                        </div>
                    }

                    <div class="alert alert-info mt-4">
                        <i class="bi bi-info-circle"></i> 
                        <strong>Importante:</strong> Apresente este código no check-in. Um email de confirmação foi enviado para @Model.EmailHospede.
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <a asp-action="Index" class="btn btn-outline-primary">
                            <i class="bi bi-house"></i> Voltar ao Início
                        </a>
                        <a asp-action="Reservar" class="btn btn-gold">
                            <i class="bi bi-calendar-plus"></i> Nova Reserva
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
